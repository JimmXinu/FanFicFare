msgid ""
"When an update or overwrite of an existing story fails, record the reason in this column.\n"
"(Text and Long Text columns only.)"
msgstr "Když aktualizace nebo přepsání existujícího příběhu selže, zaznamenat důvod do tohoto sloupce.\n(Pouze textové sloupce a sloupce dlouhého textu.)"

#: config.py:1506
